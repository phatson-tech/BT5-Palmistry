from keras.models import load_model
from keras.utils import load_img, img_to_array
import numpy as np
import matplotlib.pyplot as plt

model = load_model("/content/drive/MyDrive/DATA_AI/palmistry/palmistry_model_v1.h5")

class_labels = ['Tay_Binh_Thuong', 'Tay_Chu_M'] 

path_to_test_image = "/content/116_IMG__(4).JPG" 

img = load_img(path_to_test_image, target_size=(200, 200))
plt.imshow(img)
plt.axis('off')
plt.show()

img_arr = img_to_array(img)
img_arr = img_arr / 255.0
img_arr = img_arr.reshape(1, 200, 200, 3)

tu_dien_boi_toan = {
    'Tay_Chu_M': "BÀN TAY CHỮ M: Sở hữu trực giác nhạy bén, tố chất lãnh đạo xuất chúng và dễ đạt được thành tựu lớn về mặt tài chính trong sự nghiệp. Là người có ý chí mạnh mẽ.",
    'Tay_Binh_Thuong': "BÀN TAY TIÊU CHUẨN: Các đường nét cơ bản rõ ràng, thể hiện một cuộc sống cân bằng, ít sóng gió. Phù hợp với sự ổn định và phát triển bản thân theo lộ trình chắc chắn."
}

prediction = np.argmax(model.predict(img_arr))
result = class_labels[prediction]

print(">>> KẾT QUẢ DỰ ĐOÁN CỦA AI:", result)
print(tu_dien_boi_toan[result])
