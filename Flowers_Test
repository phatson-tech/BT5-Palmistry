from keras.models import load_model
from keras.utils import load_img, img_to_array
import numpy as np
import matplotlib.pyplot as plt

model = load_model("/content/drive/MyDrive/DATA_AI/flowers/flower_model.h5")

class_labels = ['Cúc họa mi (Daisy)', 'Bồ công anh (Dandelion)', 'Hoa hồng (Rose)', 'Hướng dương (Sunflower)', 'Hoa Tulip'] 

path_to_test_image = "/content/dandelion2.jpg" 

img = load_img(path_to_test_image, target_size=(200, 200))
plt.imshow(img)
plt.axis('off')
plt.show()

img_arr = img_to_array(img)
img_arr = img_arr / 255.0
img_arr = img_arr.reshape(1, 200, 200, 3)

prediction = np.argmax(model.predict(img_arr))
result = class_labels[prediction]

print(">>> AI NHẬN DIỆN ĐÂY LÀ:", result)
